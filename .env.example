# Raiz do vault (repo Git) que o servidor expõe.
# No repo RonaldoMerussi/SecondBrain, o vault Obsidian vive na subpasta SecondBrain/,
# não na raiz do repo — aponte VAULT_PATH para o clone + essa subpasta.
VAULT_PATH=/data/vault/SecondBrain

# Bearer token exigido em todas as requisições (Authorization: Bearer <token>).
MCP_AUTH_TOKEN=changeme

# Remote git usado para pull/push automático.
GIT_REMOTE=origin

# Autor dos commits automáticos feitos pelo servidor.
GIT_AUTHOR=MCP Bot <mcp@bot>

# Segundos entre pulls de frescor em background. 0 desliga o pull periódico.
SYNC_PULL_INTERVAL=300

# Libera overwrite/delete. Mantenha "false" em produção.
ALLOW_DESTRUCTIVE=false

# Porta do uvicorn.
PORT=8000
